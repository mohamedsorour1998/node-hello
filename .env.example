# Copy to `.env` (gitignored) for local runs. Do NOT commit real secrets.

# HTTP server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# New Relic (monitoring & log forwarding). Leave the license key empty to run
# without New Relic. When set, the agent is loaded automatically at startup.
NEW_RELIC_APP_NAME=node-hello
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_LOG_LEVEL=info
